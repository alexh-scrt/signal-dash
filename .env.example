# .env.example — copy this file to .env and fill in your values.
# signal_dash reads these variables on startup via pydantic-settings.
# All variables have sensible defaults; the only one *required* for full
# LLM-backed classification is OPENAI_API_KEY.

# ---------------------------------------------------------------------------
# Core keyword monitoring
# ---------------------------------------------------------------------------

# Primary keyword / brand name to track across all sources.
KEYWORD=python

# ---------------------------------------------------------------------------
# Source selection
# ---------------------------------------------------------------------------

# Comma-separated list of sources to enable. Options: reddit, mastodon
SOURCES=reddit,mastodon

# ---------------------------------------------------------------------------
# Polling / scheduler
# ---------------------------------------------------------------------------

# How often (seconds) the background job polls each source. Minimum: 30.
REFRESH_INTERVAL_SECONDS=300

# ---------------------------------------------------------------------------
# Reddit ingestion (no auth required — uses the public JSON API)
# ---------------------------------------------------------------------------

# Base URL for Reddit (override in tests or when using a mirror).
# REDDIT_BASE_URL=https://www.reddit.com

# Subreddit to search within. Default is r/all (all subreddits).
# REDDIT_SUBREDDIT=all

# Max posts to fetch per poll (1–100).
# REDDIT_POST_LIMIT=25

# User-Agent sent to Reddit. Must be descriptive per Reddit API rules.
# REDDIT_USER_AGENT=signal_dash/0.1.0 (social listening bot)

# ---------------------------------------------------------------------------
# Mastodon ingestion (public timeline, no auth required)
# ---------------------------------------------------------------------------

# Mastodon instance base URL.
# MASTODON_BASE_URL=https://mastodon.social

# Max statuses to fetch per poll (1–40).
# MASTODON_POST_LIMIT=20

# ---------------------------------------------------------------------------
# LLM / OpenAI classifier
# ---------------------------------------------------------------------------

# OpenAI API key. Leave blank to use the built-in rule-based stub classifier
# (zero network calls — great for development and CI).
OPENAI_API_KEY=

# OpenAI model used for classification. gpt-4o-mini offers the best
# cost/quality trade-off for short social media snippets.
# OPENAI_MODEL=gpt-4o-mini

# Number of posts batched into a single LLM request (1–50).
# CLASSIFIER_BATCH_SIZE=10

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------

# Path to the SQLite database file. Use :memory: for ephemeral in-memory DB.
# DATABASE_URL=signal_dash.db

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Host and port for the uvicorn server.
# HOST=0.0.0.0
# PORT=8000

# Enable FastAPI/uvicorn debug mode (auto-reload). Do NOT use in production.
# DEBUG=false
